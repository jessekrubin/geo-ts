{
  "name": "@jsse/geo-ts",
  "type": "module",
  "version": "0.0.3",
  "private": true,
  "description": "geo-json-schemas by way of typebox",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "scripts": {
    "build": "pnpm run -r build",
    "build-fast": "tsup src/index.ts --format cjs,esm",
    "build:tsup": "tsup src/index.ts --format cjs,esm --dts",
    "change": "changeset",
    "dev": "vitest watch",
    "fmt": "prettier --write .",
    "fmtc": "prettier --check .",
    "fmtl": "prettier --list-different .",
    "lint": "eslint .",
    "publish": "pnpm publish -r",
    "release": "pnpm run -r build && changeset publish",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile && pnpm fmt",
    "ci:publish": "pnpm publish -r",
    "test": "vitest run && vitest typecheck --run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@jsse/eslint-config": "^0.1.21",
    "eslint": "^8.57.0",
    "prettier": "3.3.3",
    "tsup": "8.2.3",
    "tsx": "^4.16.4",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
