{
  "name": "@jsse/geo-ts",
  "type": "module",
  "version": "0.0.3",
  "private": true,
  "description": "geo-json-schemas by way of typebox",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "scripts": {
    "build": "pnpm run lint",
    "build-fast": "tsup src/index.ts --format cjs,esm",
    "build:tsup": "tsup src/index.ts --format cjs,esm --dts",
    "change": "changeset",
    "dev": "vitest watch",
    "fmt": "prettier --write .",
    "fmtc": "prettier --check .",
    "fmtl": "prettier --list-different .",
    "lint": "eslint .",
    "prepublish": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "publish": "pnpm publish -r",
    "test": "vitest run && vitest typecheck --run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.3",
    "@jsse/eslint-config": "^0.1.15",
    "eslint": "^9.3.0",
    "prettier": "3.2.5",
    "tsup": "8.0.2",
    "tsx": "^4.10.5",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
