{
  "name": "@jsse/geo-ts",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "geo-json-schemas by way of typebox",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "license": "MIT",
  "scripts": {
    "prepublish": "pnpm run build",
    "build-fast": "tsup src/index.ts --format cjs,esm",
    "build": "pnpm run lint && pnpm run test && pnpm run build:tsup",
    "build:tsup": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run && vitest typecheck --run",
    "dev": "vitest watch",
    "lint": "eslint src/** ./package.json",
    "fmt": "prettier --write .",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@jsse/eslint-config": "^0.0.1",
    "eslint": "^8.50.0",
    "prettier": "3.0.3",
    "tsup": "7.2.0",
    "tsx": "^3.13.0",
    "typescript": "5.2.2",
    "vitest": "0.34.6"
  }
}
