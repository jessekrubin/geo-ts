{
  "name": "@jsse/geotypes",
  "type": "module",
  "version": "0.0.15",
  "description": "geo types",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build-fast": "tsup src/geojson.ts --format cjs,esm",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tsd.json",
    "build": "pnpm run typecheck && pnpm run build:tsup && pnpm run build:tsc",
    "build:tsc": "tsc",
    "build:indexes": "tsx ./build.mts",
    "build:tsup": "tsup --format cjs,esm --dts",
    "test": "vitest run",
    "dev": "vitest watch --coverage",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "prepare": "pnpm run build"
  },
  "devDependencies": {
    "@jsse/eslint-config": "^0.2.1",
    "@types/geojson": "^7946.0.14",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "@vitest/coverage-v8": "^2.0.5",
    "esbuild": "^0.23.0",
    "eslint": "^8.56.0",
    "prettier": "3.3.3",
    "tsup": "8.2.4",
    "tsx": "^4.16.5",
    "typescript": "5.5.4",
    "vitest": "2.0.5",
    "zx": "^8.1.4"
  }
}
