{
  "name": "@jsse/geotypia",
  "type": "module",
  "version": "0.0.3",
  "description": "@jsse/geotypes + typia",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./pacakge.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build-fast": "tsup src/index.ts --format cjs,esm",
    "build": "pnpm run gen && pnpm run build:tsc",
    "build:tsc": "tsc",
    "build:tsup": "tsup --format cjs,esm",
    "build:dts": "tsc --emitDeclarationOnly",
    "gen": "tsx build.mts prebuild && pnpm run gen:typia",
    "gen:typia": "typia generate --input src/typia-src --output src/generated --project tsconfig.json",
    "test": "vitest run",
    "dev": "vitest watch --coverage",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "prepublishOnly": "pnpm run build",
    "prepare": "ts-patch install"
  },
  "dependencies": {
    "@jsse/geotypes": "workspace:*"
  },
  "devDependencies": {
    "@jsse/eslint-config": "^0.1.6",
    "@microsoft/api-extractor": "^7.43.0",
    "@types/geojson": "^7946.0.14",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "@vitest/coverage-v8": "^1.4.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "prettier": "3.2.5",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.1.2",
    "tsup": "8.0.2",
    "tsx": "^4.7.1",
    "typescript": "5.4.3",
    "typia": "^5.5.7",
    "vitest": "1.4.0",
    "zx": "^7.2.3"
  }
}
