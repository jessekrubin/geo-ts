{
  "name": "@jsse/geo",
  "type": "module",
  "version": "0.0.9",
  "description": "geo typescript",
  "author": "jessekrubin",
  "license": "MIT",
  "keywords": [],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build-fast": "tsup src/index.ts --format cjs,esm",
    "build": "pnpm run build:tsup && pnpm run build:tsc",
    "build:tsup": "tsup --format cjs,esm --dts",
    "build:tsc": "tsc --project tsconfig.json && tsc --project tsconfig.cjs.json",
    "test": "vitest run",
    "cov": "vitest run --coverage",
    "dev": "vitest watch --coverage",
    "lint": "eslint .",
    "fmt": "prettier --write . --ignore-path ../../.prettierignore",
    "nodetest": "node --import tsx --test ./src/*test.ts",
    "prepare": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@jsse/geotypes": "^0.0.9"
  },
  "devDependencies": {
    "@jsse/eslint-config": "^0.1.17",
    "@jsse/geotypes": "workspace:*",
    "@jsse/tsconfig": "^0.0.3",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.56.0",
    "prettier": "^3.3.2",
    "tsup": "^8.1.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
